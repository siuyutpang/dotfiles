[module/date]
type             = internal/date
interval         = 1
date             = ÔĀ≥ %Y/%m/%d
label            = %date%
label-foreground = ${colors.purple}
label-underline  = ${colors.purple}

[module/time]
type             = internal/date
interval         = 1
date             = ÔÄó %H:%M:%S
label            = %date%
label-foreground = ${colors.purple}
label-underline  = ${colors.purple}


[settings]
screenchange-reload = true
pseudo-transparency = true

; vim:ft=dosini
